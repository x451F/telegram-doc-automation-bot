BOT_TOKEN=replace-with-your-bot-token
PARSE_MODE=HTML
LOG_LEVEL=INFO

OUTPUT_DIR=./output
TEMPLATES_DIR=./app/templates
DATA_DIR=./app/data
WORK_ITEMS_FILE=./app/data/work_items.example.json

ENABLE_PDF_CONVERSION=false
ENABLE_ZIP_EXPORT=true
ALLOWED_TEMPLATE_EXTENSIONS=.docx

# Comma-separated Telegram user IDs. Leave empty to allow all users.
ADMIN_ALLOWLIST=
